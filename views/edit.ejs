<!DOCTYPE html>

<html>

<head>

<title>Edit</title>

<link href=
"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h1>Edit Student</h1>

<form
action="/update/<%= student._id %>?_method=PUT"
method="POST">

<input
type="text"
name="name"
value="<%= student.name %>"
class="form-control mb-3">

<input
type="text"
name="dept"
value="<%= student.dept %>"
class="form-control mb-3">

<button class="btn btn-success">
Update
</button>

</form>

</div>

</body>

</html>